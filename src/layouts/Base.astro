---
const { title = 'Min', description = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<!doctype html>
<html lang="zh-Hant">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}
    <meta property="og:title" content={title} />
    {description && <meta property="og:description" content={description} />}
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
          return localStorage.getItem('theme');
        }
        if (window.matchMedia('(prefers-color-scheme: light)').matches) {
          return 'light';
        }
        return 'dark';
      })();
      if (theme === 'light') {
        document.documentElement.classList.add('light');
      } else {
        document.documentElement.classList.remove('light');
      }
    </script>
    <style is:global>
      :root {
        --bg: #0c0d11;
        --surface: #16181f;
        --surface-2: #1d2029;
        --text: #eceef4;
        --muted: #969cab;
        --accent: #6c8cff;
        --accent-2: #a06bff;
        --border: #252934;
      }
      html.light {
        --bg: #f5f6fa;
        --surface: #ffffff;
        --surface-2: #eef1f6;
        --text: #1b1e28;
        --muted: #6b7280;
        --accent: #3b82f6;
        --accent-2: #8b5cf6;
        --border: #e2e8f0;
      }
      html.light .bg-glow::before { opacity: .38; }
      html.light .bg-glow::after { opacity: .28; }
      html.light header.site nav a.active {
        text-shadow: 0 0 10px rgba(59, 130, 246, 0.4);
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html { scroll-behavior: smooth; }
      body {
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI",
          "PingFang TC", "Microsoft JhengHei", sans-serif;
        background: var(--bg);
        color: var(--text);
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
        overflow-x: hidden;
      }
      .wrap { max-width: 760px; margin: 0 auto; padding: 0 24px; }

      /* 背景氛圍光暈 */
      .bg-glow {
        position: fixed; inset: 0; z-index: -1; pointer-events: none;
        overflow: hidden;
      }
      .bg-glow::before, .bg-glow::after {
        content: ''; position: absolute; border-radius: 50%;
        filter: blur(90px); opacity: .35;
        will-change: transform;
      }
      .bg-glow::before {
        width: 480px; height: 480px; top: -160px; left: -120px;
        background: radial-gradient(circle, var(--accent), transparent 70%);
        animation: float-glow-1 25s infinite ease-in-out;
      }
      .bg-glow::after {
        width: 420px; height: 420px; top: 80px; right: -140px;
        background: radial-gradient(circle, var(--accent-2), transparent 70%);
        opacity: .25;
        animation: float-glow-2 20s infinite ease-in-out;
      }

      @keyframes float-glow-1 {
        0% { transform: translate(0, 0) scale(1); }
        33% { transform: translate(40px, 30px) scale(1.08); }
        66% { transform: translate(-20px, 45px) scale(0.95); }
        100% { transform: translate(0, 0) scale(1); }
      }
      @keyframes float-glow-2 {
        0% { transform: translate(0, 0) scale(1); }
        50% { transform: translate(-35px, -40px) scale(1.06); }
        100% { transform: translate(0, 0) scale(1); }
      }
      @media (prefers-reduced-motion: reduce) {
        .bg-glow::before, .bg-glow::after {
          animation: none !important;
        }
      }

      /* 滑入淡入動畫 */
      @media (prefers-reduced-motion: no-preference) {
        .reveal { opacity: 0; transform: translateY(20px); transition: opacity .6s ease, transform .6s ease; }
        .reveal.in { opacity: 1; transform: none; }
      }

      /* header */
      header.site {
        border-bottom: 1px solid var(--border);
        padding: 16px 0;
        position: sticky; top: 0;
        background: color-mix(in srgb, var(--bg) 80%, transparent);
        backdrop-filter: blur(12px);
        z-index: 10;
      }
      header.site .wrap { display: flex; justify-content: space-between; align-items: center; }
      header.site a.logo {
        font-weight: 700; color: var(--text); text-decoration: none; font-size: 17px;
        letter-spacing: .3px;
      }
      header.site nav a { color: var(--muted); text-decoration: none; margin-left: 22px; font-size: 14px; transition: color .2s, text-shadow .2s; }
      header.site nav a:hover, header.site nav a.active { color: var(--text); }
      header.site nav a.active {
        font-weight: 600;
        text-shadow: 0 0 10px rgba(108, 140, 255, 0.6);
      }

      /* Theme Toggle Button */
      .theme-toggle-btn {
        background: none; border: none; cursor: pointer;
        color: var(--muted); margin-left: 22px; width: 32px; height: 32px;
        display: flex; align-items: center; justify-content: center;
        border-radius: 8px; transition: color 0.25s, background-color 0.25s, transform 0.25s;
        outline: none;
      }
      .theme-toggle-btn:hover {
        color: var(--text);
        background-color: var(--surface-2);
        transform: scale(1.05);
      }
      .theme-toggle-btn:active {
        transform: scale(0.95);
      }
      .theme-toggle-btn svg {
        width: 18px;
        height: 18px;
        stroke: currentColor;
      }
      html.light .theme-toggle-btn .sun { display: none; }
      html:not(.light) .theme-toggle-btn .moon { display: none; }

      main { padding: 0 0 96px; }
      section { padding: 56px 0 0; }
      h1 { font-size: clamp(32px, 6vw, 46px); line-height: 1.15; margin-bottom: 18px; letter-spacing: -.5px; }
      h2 {
        font-size: 14px; text-transform: uppercase; letter-spacing: 2px;
        color: var(--muted); margin-bottom: 20px; font-weight: 600;
      }
      h3 { font-size: 18px; margin: 24px 0 8px; }
      p, li { color: var(--text); margin-bottom: 12px; }
      a { color: var(--accent); }
      .muted { color: var(--muted); }
      ul { padding-left: 22px; margin-bottom: 12px; }

      /* hero */
      .hero { padding-top: 72px; }
      .hero .lead { font-size: 19px; color: var(--muted); max-width: 560px; }
      .hero .accent { color: var(--text); font-weight: 600; }
      .gradient-text {
        background: linear-gradient(120deg, var(--accent), var(--accent-2));
        -webkit-background-clip: text; background-clip: text;
        -webkit-text-fill-color: transparent;
      }

      /* buttons */
      .btn-row { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 28px; }
      .btn {
        display: inline-flex; align-items: center; gap: 8px;
        padding: 11px 22px; border-radius: 12px; text-decoration: none;
        font-size: 14px; font-weight: 600;
        transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
      }
      .btn:hover { transform: translateY(-3px); }
      .btn:active { transform: translateY(-1px); }
      .btn-primary {
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        background-size: 200% 200%;
        color: #0c0d11;
        box-shadow: 0 4px 14px rgba(108, 140, 255, 0.35);
      }
      .btn-primary:hover {
        background-position: right center;
        box-shadow: 0 6px 20px rgba(108, 140, 255, 0.5);
      }
      .btn-ghost {
        background: var(--surface);
        color: var(--text);
        border: 1px solid var(--border);
      }
      .btn-ghost:hover {
        background: var(--surface-2);
        border-color: var(--muted);
      }

      /* cards */
      .card {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 24px;
        margin: 14px 0;
        display: block;
        text-decoration: none;
        color: var(--text);
        transition: border-color .2s, transform .15s, background .2s;
      }
      a.card:hover { border-color: var(--accent); transform: translateY(-3px); background: var(--surface-2); }
      .card .row { display: flex; align-items: center; gap: 12px; }
      .card .emoji { font-size: 28px; }

      /* tags */
      .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
      .tag {
        font-size: 12.5px; color: var(--muted);
        background: var(--surface-2); border: 1px solid var(--border);
        border-radius: 999px; padding: 4px 12px;
      }

      /* skills grid */
      .skill-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 12px; }
      .skill {
        background: var(--surface); border: 1px solid var(--border);
        border-radius: 12px; padding: 14px 16px; font-size: 14px;
        transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
        display: flex; align-items: center; gap: 12px;
      }
      .skill:hover {
        transform: translateY(-3px);
        border-color: var(--accent);
        background: var(--surface-2);
        box-shadow: 0 8px 24px -8px rgba(108, 140, 255, 0.25);
      }
      .skill .si {
        font-size: 24px;
        transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        display: inline-block;
      }
      .skill:hover .si {
        transform: scale(1.2) rotate(8deg);
      }
      .skill .k { font-weight: 600; }
      .skill .v { color: var(--muted); font-size: 12.5px; }

      /* footer */
      footer.site {
        border-top: 1px solid var(--border);
        padding: 32px 0; color: var(--muted); font-size: 13px;
        margin-top: 64px;
      }
      footer.site .links a { color: var(--muted); text-decoration: none; margin-right: 18px; transition: color .2s; }
      footer.site .links a:hover { color: var(--text); }

      /* Toast 提示氣泡 */
      .toast-container {
        position: fixed;
        bottom: 40px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 9999;
        display: flex;
        flex-direction: column;
        gap: 10px;
        pointer-events: none;
      }
      .toast {
        background: color-mix(in srgb, var(--surface-2) 80%, transparent);
        border: 1px solid var(--border);
        color: var(--text);
        padding: 12px 24px;
        border-radius: 14px;
        font-size: 14px;
        font-weight: 500;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
        backdrop-filter: blur(10px);
        -webkit-backdrop-filter: blur(10px);
        display: flex;
        align-items: center;
        gap: 10px;
        animation: toast-in-out 3s forwards cubic-bezier(0.25, 0.8, 0.25, 1);
        pointer-events: auto;
      }
      @keyframes toast-in-out {
        0% { opacity: 0; transform: translateY(20px) scale(0.95); }
        8% { opacity: 1; transform: translateY(0) scale(1); }
        92% { opacity: 1; transform: translateY(0) scale(1); }
        100% { opacity: 0; transform: translateY(-15px) scale(0.97); }
      }
      /* 頁尾訪客計數標籤 */
      .tag-visitor {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        font-size: 11.5px;
        color: var(--muted);
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 4px 10px;
        border-radius: 999px;
        line-height: 1;
      }
      .tag-visitor .visitor-dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: #3ddc97;
        box-shadow: 0 0 6px #3ddc97;
        animation: visitor-pulse 2s infinite;
      }
      @keyframes visitor-pulse {
        0% { opacity: 0.4; }
        50% { opacity: 1; }
        100% { opacity: 0.4; }
      }
    </style>
  </head>
  <body>
    <div class="bg-glow"></div>
    <header class="site">
      <div class="wrap">
        <a class="logo" href={`${base}/`}>Min<span style="color:var(--accent)">.</span></a>
        <nav style="display: flex; align-items: center;">
          <a href={`${base}/#about`}>關於</a>
          <a href={`${base}/#projects`}>作品</a>
          <a href={`${base}/#contact`}>聯絡</a>
          <button id="themeToggle" class="theme-toggle-btn" aria-label="切換主題">
            <svg class="sun" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="5"></circle>
              <line x1="12" y1="1" x2="12" y2="3"></line>
              <line x1="12" y1="21" x2="12" y2="23"></line>
              <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
              <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
              <line x1="1" y1="12" x2="3" y2="12"></line>
              <line x1="21" y1="12" x2="23" y2="12"></line>
              <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
              <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
            </svg>
            <svg class="moon" viewBox="0 0 24 24" fill="none" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
            </svg>
          </button>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site">
      <div class="wrap">
        <div class="links" style="margin-bottom:8px;">
          <a href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub</a>
          <a href="mailto:n200127@gmail.com">Email</a>
        </div>
        <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:8px;">
          <span>© {new Date().getFullYear()} Min</span>
          <!-- 不蒜子 UV 訪客計數器顯示容器 -->
          <span id="busuanzi_container_site_uv" class="tag-visitor" style="display:none;">
            <span class="visitor-dot"></span>
            <span>訪客數 <span id="busuanzi_value_site_uv">--</span></span>
          </span>
        </div>
      </div>
    </footer>
    <div id="toastContainer" class="toast-container"></div>
    <script>
      // 區塊滑入時淡入（無 JS 時內容照常顯示）
      const mq = window.matchMedia('(prefers-reduced-motion: no-preference)');
      if (mq.matches) {
        const els = document.querySelectorAll('main section');
        els.forEach((el) => el.classList.add('reveal'));
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); }
          });
        }, { threshold: 0.12 });
        els.forEach((el) => io.observe(el));
      }

      // 導覽列滾動主動感應 (Scrollspy)
      const sections = document.querySelectorAll('main section');
      const navLinks = document.querySelectorAll('header.site nav a');
      if (sections.length > 0 && navLinks.length > 0) {
        window.addEventListener('scroll', () => {
          let current = '';
          const scrollPos = window.scrollY + 120;
          sections.forEach(sec => {
            const top = sec.offsetTop;
            const height = sec.offsetHeight;
            if (scrollPos >= top && scrollPos < top + height) {
              current = sec.getAttribute('id') || '';
            }
          });
          navLinks.forEach(link => {
            link.classList.remove('active');
            const href = link.getAttribute('href') || '';
            if (current && href.endsWith('#' + current)) {
              link.classList.add('active');
            }
          });
        });
      }

      // 主題切換 (Light / Dark Theme Toggle)
      const themeToggle = document.getElementById('themeToggle');
      if (themeToggle) {
        themeToggle.addEventListener('click', () => {
          const isLight = document.documentElement.classList.toggle('light');
          localStorage.setItem('theme', isLight ? 'light' : 'dark');
        });
      }

      // 全域 Toast 氣泡通知發送器
      // @ts-ignore
      window.showToast = function (message) {
        const container = document.getElementById('toastContainer');
        if (!container) return;
        const toast = document.createElement('div');
        toast.className = 'toast';
        toast.innerHTML = `
          <svg style="width:16px; height:16px; color:var(--accent); flex-shrink:0;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          <span style="white-space:nowrap;">${message}</span>
        `;
        container.appendChild(toast);
        // 動畫結束後自動移除元素
        setTimeout(() => {
          toast.remove();
        }, 3000);
      };

      // 動態加載防灌水不蒜子統計 (UV 計數器)
      // @ts-ignore
      const isDev = window.location.hostname === 'localhost' || 
                    window.location.hostname === '127.0.0.1' || 
                    localStorage.getItem('exclude_stats') === 'true';

      if (!isDev) {
        // 非開發者環境：動態插入不蒜子統計代碼
        const script = document.createElement('script');
        script.async = true;
        script.src = 'https://busuanzi.ibruce.info/busuanzi/2.3/busuanzi.pure.mini.js';
        document.head.appendChild(script);
      } else {
        // 開發者環境/本地：顯示計數器並標記為已排除，方便開發者驗證
        const container = document.getElementById('busuanzi_container_site_uv');
        if (container) {
          container.style.display = 'inline-flex';
          const valEl = document.getElementById('busuanzi_value_site_uv');
          if (valEl) {
            valEl.innerText = '已排除';
          }
          // 將綠色圓點切換為灰色
          const dot = container.querySelector('.visitor-dot');
          if (dot) {
            // @ts-ignore
            dot.style.background = 'var(--muted)';
            // @ts-ignore
            dot.style.boxShadow = 'none';
            // @ts-ignore
            dot.style.animation = 'none';
          }
        }
      }
    </script>
  </body>
</html>
