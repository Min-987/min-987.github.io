---
import Base from '../layouts/Base.astro';
---
<Base title="加入 ExpiryRP 群組" description="使用邀請碼加入 ExpiryRP 的家庭群組。">

  <section class="hero" style="text-align:center;">
    <div class="wrap">
      <div style="font-size:52px; line-height:1;">📦</div>
      <h1 style="margin-top:14px;">加入群組邀請</h1>
      <p class="lead" id="hint" style="margin:0 auto;">正在讀取邀請碼…</p>

      <div id="codeBox" style="display:none; margin:20px auto 0; max-width:280px;">
        <div style="font-size:13px; color:var(--muted); margin-bottom:4px;">邀請碼</div>
        <div id="codeText" style="font-size:28px; font-weight:700; letter-spacing:4px;"></div>
      </div>

      <div class="btn-row" style="justify-content:center; margin-top:24px;">
        <a id="openAppBtn" class="btn btn-primary" href="#">在 App 內開啟</a>
      </div>
      <p style="margin-top:16px; font-size:13px; color:var(--muted);">
        還沒有 ExpiryRP？請向邀請你的人取得 App，目前尚未上架到 App Store / Play 商店。
      </p>
    </div>
  </section>

  <script>
    const params = new URLSearchParams(window.location.search);
    const code = params.get('code');
    const hint = document.getElementById('hint');
    const codeBox = document.getElementById('codeBox');
    const codeText = document.getElementById('codeText');
    const openAppBtn = document.getElementById('openAppBtn');

    if (code) {
      hint.textContent = '點下方按鈕，在 App 內完成加入：';
      codeBox.style.display = 'block';
      codeText.textContent = code;
      openAppBtn.setAttribute('href', `expiryrp://join?code=${encodeURIComponent(code)}`);
      // 若已安裝 App 但 Universal Link 還沒生效，嘗試自動喚醒一次
      window.location.replace(`expiryrp://join?code=${encodeURIComponent(code)}`);
    } else {
      hint.textContent = '邀請連結缺少邀請碼，請確認連結是否完整。';
      openAppBtn.style.display = 'none';
    }
  </script>

</Base>
