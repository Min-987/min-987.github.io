---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const skills = [
  { icon: '📱', k: '行動 App', v: 'iOS · Android' },
  { icon: '☁️', k: '雲端服務', v: '帳號登入、資料同步' },
  { icon: '🌐', k: '網站', v: '像你正在看的這個' },
  { icon: '🤖', k: 'AI 協作', v: '用 AI 加速開發' },
];

const projects = [
  {
    href: `${base}/expiryrp`,
    emoji: '📦',
    title: 'ExpiryRP',
    sub: '到期日管理工具',
    desc: '掃描條碼記錄物品到期日，到期前主動提醒，減少食物與用品的浪費。支援家庭共享、消耗統計與 iOS 桌面小工具。',
    tags: ['Flutter', 'Firebase', 'iOS Widget', '即將上架'],
    g1: '#3ddc97', g2: '#2bb8c4',
  },
  {
    href: `${base}/psd-to-png`,
    emoji: '🖼️',
    title: 'PSD Layer to PNG',
    sub: 'PSD 圖層轉 PNG 工具',
    desc: '把 PSD 檔的每個圖層各自輸出成獨立 PNG，並保留原始位置。支援群組圖層、自動編號，可打包成免安裝執行檔。',
    tags: ['Python', '桌面工具', '開源'],
    g1: '#a06bff', g2: '#e36bd0',
  },
  {
    href: `${base}/liquid-focus`,
    emoji: '🍅',
    title: 'Liquid Focus',
    sub: '液態番茄鐘',
    desc: '滿版液態動畫的番茄鐘，時間流逝化為上升的液面與氣泡，配上即時合成的柔和音效。打開即用，專注更有儀式感。',
    tags: ['Web', 'Canvas / SVG', 'Web Audio'],
    g1: '#5B4FFF', g2: '#FF4FB8',
  },
];
---
<Base title="Min — 個人網站" description="Min 的個人網站與作品集。打造實用的行動應用。">

  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="status-row">
        <span class="pill"><span class="dot"></span>開放專案合作</span>
        <span class="pill">📲 ExpiryRP 即將上架</span>
      </div>
      <h1>嗨，我是 <span class="gradient-text">Min</span> 👋<br/>我打造實用的 App。</h1>
      <p class="lead">
        喜歡把生活中的小麻煩，變成<span class="accent">好用的工具</span>。
        善用各種工具把腦中的點子做成真的能用的東西。
      </p>
      <div class="btn-row">
        <a class="btn btn-primary" href={`${base}/#projects`}>看我的作品</a>
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="wrap">
      <h2><span class="num">01</span> 關於我</h2>
      <p>
        比起鑽研艱深的技術，我更在意一個東西<strong>好不好用、能不能真的解決問題</strong>。
        我喜歡從一個生活中的小困擾出發，一步步把它變成可以實際使用的產品。
      </p>
      <p class="muted">
        在各種現代工具（包含 AI）的協助下，我能把想法快速做成成品——
        ExpiryRP 就是這樣誕生的。我享受這個從零到一、邊做邊學的過程。
      </p>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="wrap">
      <h2><span class="num">02</span> 涉獵領域</h2>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill">
            <span class="si">{s.icon}</span>
            <div>
              <div class="k">{s.k}</div>
              <div class="v">{s.v}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="wrap">
      <h2><span class="num">03</span> 作品</h2>
      <div class="project-list">
        {projects.map((p) => (
          <a class="project" href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener' : undefined} style={`--g1:${p.g1}; --g2:${p.g2};`}>
            <div class="banner"><span>{p.emoji}</span></div>
            <div class="pbody">
              <div class="ptitle">
                <strong>{p.title}</strong>
                <span class="muted">{p.sub}</span>
              </div>
              <p class="muted pdesc">{p.desc}</p>
              <div class="tags">
                {p.tags.map((t) => <span class="tag">{t}</span>)}
                <span class="tag tag-update" id={`update-${p.href.split('/').pop()}`}></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="wrap">
      <h2><span class="num">04</span> 聯絡</h2>
      <p>有專案合作、工作機會或單純想聊聊，都歡迎直接填寫表單，或複製 Email 信箱 👇</p>
      
      <!-- HubSpot 嵌入表單 (改為自訂原生表單以完美契合樣式) -->
      <div class="form-container">
        <form id="hsContactForm" class="contact-form">
          <div class="form-group">
            <label for="formName">您的名字</label>
            <input type="text" id="formName" name="firstname" required placeholder="例如：王小明" />
          </div>
          <div class="form-group">
            <label for="formEmail">電子信箱</label>
            <input type="email" id="formEmail" name="email" required placeholder="your.email@example.com" />
          </div>
          <div class="form-group">
            <label for="formMessage">訊息內容</label>
            <textarea id="formMessage" name="message" required placeholder="想對我說的話..." rows="5"></textarea>
          </div>
          <button type="submit" id="formSubmitBtn" class="btn btn-primary" style="border: none; cursor: pointer; margin-top: 10px;">
            送出訊息
          </button>
        </form>
      </div>

      <div class="btn-row">
        <button id="copyEmailBtn" class="btn btn-primary" style="cursor: pointer; border: none; font-family: inherit;">
          <svg style="width: 15px; height: 15px; fill: none; stroke: currentColor; stroke-width: 2.2; flex-shrink: 0;" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
            <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
            <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"></path>
          </svg>
          <span id="copyEmailText">複製 Email 信箱</span>
        </button>
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <style>
    /* 狀態標籤 */
    .status-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 22px; }
    .pill {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 13px; color: var(--muted);
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 999px; padding: 6px 14px;
    }
    .pill .dot {
      width: 8px; height: 8px; border-radius: 50%; background: #3ddc97;
      box-shadow: 0 0 0 0 rgba(61,220,151,.6); animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(61,220,151,.5); }
      70% { box-shadow: 0 0 0 7px rgba(61,220,151,0); }
      100% { box-shadow: 0 0 0 0 rgba(61,220,151,0); }
    }

    /* 區段編號 */
    h2 .num {
      color: var(--accent); font-weight: 700; margin-right: 8px;
      -webkit-text-fill-color: var(--accent);
    }

    /* 技能：加圖示 */
    .skill { display: flex; align-items: center; gap: 12px; }
    .skill .si { font-size: 24px; }

    /* 作品卡：彩色漸層橫幅 */
    .project-list { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    .project {
      display: block; text-decoration: none; color: var(--text);
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 18px; overflow: hidden;
      transition: transform 0.25s cubic-bezier(0.25, 0.8, 0.25, 1),
                  border-color 0.25s,
                  box-shadow 0.25s;
    }
    .project:hover {
      transform: translateY(-5px);
      border-color: var(--g2);
      box-shadow: 0 12px 30px -10px color-mix(in srgb, var(--g2) 30%, transparent);
    }
    .project .banner {
      height: 96px; display: flex; align-items: center; justify-content: center;
      background: linear-gradient(135deg, var(--g1), var(--g2));
      position: relative;
    }
    .project .banner span { font-size: 44px; filter: drop-shadow(0 2px 6px rgba(0,0,0,.25)); }
    .pbody { padding: 18px 20px 20px; }
    .ptitle { display: flex; align-items: baseline; gap: 8px; flex-wrap: wrap; }
    .ptitle strong { font-size: 17px; }
    .ptitle .muted { font-size: 13px; }
    .pdesc { font-size: 13.5px; line-height: 1.65; margin: 10px 0 0; }
    
    .tags { display: flex; flex-wrap: wrap; gap: 8px; margin-top: 14px; }
    .tag-update {
      display: none;
      align-items: center;
      gap: 4.5px;
      border-style: dashed;
      background: transparent;
      color: var(--muted);
    }

    /* 聯絡我表單容器 */
    .form-container {
      max-width: 560px;
      margin: 32px 0;
      background: var(--surface-2);
      border: 1px solid var(--border);
      padding: 32px;
      border-radius: 20px;
      box-shadow: 0 10px 40px -10px rgba(0,0,0,0.06);
    }
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 20px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
      text-align: left;
    }
    .form-group label {
      font-size: 12.5px;
      font-weight: 600;
      letter-spacing: 0.5px;
      color: var(--muted);
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      box-sizing: border-box;
      background: var(--surface);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 13px 16px;
      border-radius: 12px;
      font-size: 14px;
      font-family: inherit;
      transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: color-mix(in srgb, var(--muted) 50%, transparent);
    }
    .form-group input:hover,
    .form-group textarea:hover {
      border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--accent);
      outline: none;
      background: var(--surface-2);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
    }

    @media (max-width: 560px) {
      .project-list { grid-template-columns: 1fr; }
    }
  </style>
  
  <script is:inline>
    // 非同步向 GitHub API 抓取公開專案的最後更新時間
    const fetchRepoUpdateDate = (repoName, elementId) => {
      fetch(`https://api.github.com/repos/${repoName}`)
        .then(res => {
          if (!res.ok) throw new Error();
          return res.json();
        })
        .then(data => {
          const date = new Date(data.pushed_at || data.updated_at);
          const formatted = `更新於 ${date.getFullYear()}/${date.getMonth() + 1}/${date.getDate()}`;
          const el = document.getElementById(elementId);
          if (el) {
            el.innerHTML = `
              <svg style="width:11px; height:11px; flex-shrink:0; margin-top:0.5px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>${date.getFullYear()}/${date.getMonth() + 1}/${date.getDate()}</span>
            `;
            el.style.display = 'inline-flex';
          }
        })
        .catch(() => {});
    };

    // 只有公開且為開源儲存庫的專案拉取日期
    fetchRepoUpdateDate('Min-987/psd_to_png', 'update-psd-to-png');
    fetchRepoUpdateDate('Min-987/min-987.github.io', 'update-liquid-focus');

    // 複製信箱功能整合 Toast 提示
    const copyEmailBtn = document.getElementById('copyEmailBtn');
    const copyEmailText = document.getElementById('copyEmailText');
    const emailStr = 'n200127@gmail.com';

    if (copyEmailBtn && copyEmailText) {
      copyEmailBtn.addEventListener('click', () => {
        navigator.clipboard.writeText(emailStr).then(() => {
          copyEmailText.innerText = '已複製！';
          // @ts-ignore
          if (window.showToast) {
            // @ts-ignore
            window.showToast('Email 信箱已複製至剪貼簿！');
          }
          setTimeout(() => {
            copyEmailText.innerText = '複製 Email 信箱';
          }, 2000);
        }).catch(() => {
          // 降級備用方案：在極少數不支援 clipboard API 的瀏覽器（如極舊款 iOS 瀏覽器）中直接調起郵箱
          window.location.href = `mailto:${emailStr}`;
        });
      });
    }

    // HubSpot 客製化原生表單非同步 API 串接
    const contactForm = document.getElementById('hsContactForm');
    const formSubmitBtn = document.getElementById('formSubmitBtn');

    if (contactForm && formSubmitBtn) {
      contactForm.addEventListener('submit', (e) => {
        e.preventDefault();
        
        const originalText = formSubmitBtn.innerText;
        formSubmitBtn.innerText = '正在傳送...';
        // @ts-ignore
        formSubmitBtn.disabled = true;

        const formData = new FormData(contactForm);
        const email = formData.get('email');
        const firstname = formData.get('firstname');
        const message = formData.get('message');

        // 讀取 HubSpot Cookie (hubspotutk) 用於關聯訪客活動軌跡
        const getCookie = (name) => {
          const value = `; ${document.cookie}`;
          const parts = value.split(`; ${name}=`);
          if (parts.length === 2) return parts.pop().split(';').shift();
          return undefined;
        };
        const hutk = getCookie('hubspotutk');

        const requestData = {
          fields: [
            { name: 'email', value: email },
            { name: 'firstname', value: firstname },
            { name: 'message', value: message }
          ],
          context: {
            hutk: hutk, // 傳遞 Cookie 以連結現有聯絡人行為分析
            pageUri: window.location.href,
            pageName: document.title
          }
        };

        fetch('https://api.hsforms.com/submissions/v3/integration/submit/246598809/edd1001f-05c1-449e-a6d9-34e33a1ec796', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(requestData)
        })
        .then(res => {
          if (!res.ok) throw new Error();
          return res.json();
        })
        .then(() => {
          contactForm.reset();
          formSubmitBtn.innerText = '已成功送出！';
          // @ts-ignore
          if (window.showToast) {
            // @ts-ignore
            window.showToast('聯絡表單已成功送出，我會盡快回覆您！');
          }
          setTimeout(() => {
            formSubmitBtn.innerText = originalText;
            // @ts-ignore
            formSubmitBtn.disabled = false;
          }, 3000);
        })
        .catch(() => {
          formSubmitBtn.innerText = '傳送失敗，請重試';
          // @ts-ignore
          if (window.showToast) {
            // @ts-ignore
            window.showToast('傳送失敗，請複製 Email 直接來信！');
          }
          setTimeout(() => {
            formSubmitBtn.innerText = originalText;
            // @ts-ignore
            formSubmitBtn.disabled = false;
          }, 3000);
        });
      });
    }
  </script>
</Base>
