---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const skills = [
  { icon: '📱', k: '行動 App', v: 'iOS · Android' },
  { icon: '☁️', k: '雲端服務', v: '帳號登入、資料同步' },
  { icon: '🌐', k: '網站', v: '像你正在看的這個' },
  { icon: '🤖', k: 'AI 協作', v: '用 AI 加速開發' },
];

const projects = [
  {
    href: `${base}/expiryrp`,
    emoji: '📦',
    title: 'ExpiryRP',
    sub: '到期日管理工具',
    desc: '掃描條碼記錄物品到期日，到期前主動提醒，減少食物與用品的浪費。支援家庭共享、消耗統計與 iOS 桌面小工具。',
    tags: ['Flutter', 'Firebase', 'iOS Widget', '即將上架'],
    g1: '#3ddc97', g2: '#2bb8c4',
  },
  {
    href: `${base}/psd-to-png`,
    emoji: '🖼️',
    title: 'PSD Layer to PNG',
    sub: 'PSD 圖層轉 PNG 工具',
    desc: '把 PSD 檔的每個圖層各自輸出成獨立 PNG，並保留原始位置。支援群組圖層、自動編號，可打包成免安裝執行檔。',
    tags: ['Python', '桌面工具', '開源'],
    g1: '#a06bff', g2: '#e36bd0',
  },
  {
    href: `${base}/liquid-focus`,
    emoji: '🍅',
    title: 'Liquid Focus',
    sub: '液態番茄鐘',
    desc: '滿版液態動畫的番茄鐘，時間流逝化為上升的液面與氣泡，配上即時合成的柔和音效。打開即用，專注更有儀式感。',
    tags: ['Web', 'Canvas / SVG', 'Web Audio'],
    g1: '#5B4FFF', g2: '#FF4FB8',
  },
];
---
<Base title="Min — 個人網站" description="Min 的個人網站與作品集。打造實用的行動應用。">

  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <div class="status-row">
        <span class="pill"><span class="dot"></span>開放專案合作</span>
        <span class="pill">📲 ExpiryRP 即將上架</span>
      </div>
      <h1>嗨，我是 <span class="gradient-text">Min</span> 👋<br/>我打造實用的 <span class="typing-text" id="typingText">行動 App</span></h1>
      <p class="lead">
        喜歡把生活中的小麻煩，變成<span class="accent">好用的工具</span>。
        善用各種工具把腦中的點子做成真的能用的東西。
      </p>
      <div class="btn-row">
        <a class="btn btn-primary" href={`${base}/#projects`}>看我的作品</a>
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="wrap">
      <h2><span class="num">01</span> 關於我</h2>
      <p>
        比起鑽研艱深的技術，我更在意一個東西是否<span class="about-highlight-1">好不好用、能不能真的解決問題</span>。
        我喜歡從一個生活中的小困擾出發，一步步把它變成可以實際使用的產品。
      </p>
      <p class="muted">
        在各種現代工具（包含 AI）的協助下，我能把想法快速做成成品——
        ExpiryRP 就是這樣誕生的。我享受這個<span class="about-highlight-2">從零到一、邊做邊學</span>的過程。
      </p>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="wrap">
      <h2><span class="num">02</span> 涉獵領域</h2>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill">
            <span class="si">{s.icon}</span>
            <div>
              <div class="k">{s.k}</div>
              <div class="v">{s.v}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="wrap">
      <h2><span class="num">03</span> 作品</h2>
      <div class="project-list">
        {projects.map((p) => (
          <a class="project" href={p.href} target={p.external ? '_blank' : undefined} rel={p.external ? 'noopener' : undefined} style={`--g1:${p.g1}; --g2:${p.g2};`}>
            <div class="project-header">
              <div class="project-icon">
                <span>{p.emoji}</span>
              </div>
              <div class="project-title-group">
                <strong>{p.title}</strong>
                <span class="muted">{p.sub}</span>
              </div>
            </div>
            <div class="pbody">
              <p class="muted pdesc">{p.desc}</p>
              <div class="project-footer">
                <div class="tags">
                  {p.tags.map((t) => <span class="tag">{t}</span>)}
                </div>
                <span class="tag tag-update" id={`update-${p.href.split('/').pop()}`}></span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="wrap">
      <h2><span class="num">04</span> 聯絡</h2>
      <p>有專案合作、工作機會或單純想聊聊，都歡迎直接填寫表單 👇</p>
      
      <!-- HubSpot 嵌入表單 (改為自訂原生表單以完美契合樣式) -->
      <div class="form-container">
        <form id="hsContactForm" class="contact-form">
          <div class="form-group">
            <label for="formName">您的名字</label>
            <input type="text" id="formName" name="firstname" required placeholder="例如：王小明" />
          </div>
          <div class="form-group">
            <label for="formEmail">電子信箱</label>
            <input type="email" id="formEmail" name="email" required placeholder="your.email@example.com" />
          </div>
          <div class="form-group">
            <label for="formMessage">訊息內容</label>
            <textarea id="formMessage" name="message" required placeholder="想對我說的話..." rows="5"></textarea>
          </div>
          <button type="submit" id="formSubmitBtn" class="btn btn-primary" style="border: none; cursor: pointer; margin-top: 10px;">
            送出訊息
          </button>
        </form>
      </div>

      <div class="btn-row">
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <style>
    /* 打字機效果 caret 閃爍 */
    .typing-text {
      color: var(--accent);
      border-right: 2px solid var(--accent);
      padding-right: 4px;
      animation: blink-caret 0.75s step-end infinite;
      white-space: nowrap;
    }
    @keyframes blink-caret {
      from, to { border-color: transparent }
      50% { border-color: var(--accent); }
    }

    /* 關於我：精細網格背景與文字高光 */
    #about {
      position: relative;
      overflow: hidden;
    }
    #about::before {
      content: '';
      position: absolute;
      inset: 0;
      background-image: radial-gradient(color-mix(in srgb, var(--text) 18%, transparent) 1.2px, transparent 1.2px);
      background-size: 20px 20px;
      opacity: 0.8;
      pointer-events: none;
      z-index: -1;
      mask-image: radial-gradient(circle at center, black 60%, transparent 100%);
      -webkit-mask-image: radial-gradient(circle at center, black 60%, transparent 100%);
    }

    .about-highlight-1 {
      font-weight: 700;
      color: var(--text);
      position: relative;
      display: inline-block;
    }
    .about-highlight-1::after {
      content: '';
      position: absolute;
      left: 0;
      bottom: 2px;
      width: 100%;
      height: 6px;
      background: linear-gradient(90deg, var(--accent), transparent);
      z-index: -1;
      opacity: 0.4;
      border-radius: 4px;
    }
    
    .about-highlight-2 {
      font-weight: 700;
      background: linear-gradient(120deg, var(--accent-2), var(--accent));
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    /* 狀態標籤 */
    .status-row { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 22px; }
    .pill {
      display: inline-flex; align-items: center; gap: 7px;
      font-size: 13px; color: var(--muted);
      background: var(--surface); border: 1px solid var(--border);
      border-radius: 999px; padding: 6px 14px;
    }
    .pill .dot {
      width: 8px; height: 8px; border-radius: 50%; background: #3ddc97;
      box-shadow: 0 0 0 0 rgba(61,220,151,.6); animation: pulse 2s infinite;
    }
    @keyframes pulse {
      0% { box-shadow: 0 0 0 0 rgba(61,220,151,.5); }
      70% { box-shadow: 0 0 0 7px rgba(61,220,151,0); }
      100% { box-shadow: 0 0 0 0 rgba(61,220,151,0); }
    }

    /* 區段編號 */
    h2 .num {
      color: var(--accent); font-weight: 700; margin-right: 8px;
      -webkit-text-fill-color: var(--accent);
    }

    /* 技能：加圖示與高階 Glassmorphism */
    .skill-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
      gap: 16px;
      margin-top: 24px;
    }
    .skill {
      display: flex;
      align-items: center;
      gap: 14px;
      padding: 16px 20px;
      background: var(--surface);
      background: color-mix(in srgb, var(--surface) 60%, transparent);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border);
      border-radius: 16px;
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .skill:hover {
      transform: translateY(-4px);
      border-color: var(--accent-2);
      background: color-mix(in srgb, var(--surface-2) 80%, transparent);
      box-shadow: 0 10px 25px -10px color-mix(in srgb, var(--accent-2) 40%, transparent);
    }
    .skill .si {
      font-size: 24px;
      transition: transform 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
      display: inline-block;
    }
    .skill:hover .si {
      transform: scale(1.2) rotate(8deg);
    }
    .skill .k { font-weight: 600; font-size: 14.5px; }
    .skill .v { color: var(--muted); font-size: 12.5px; margin-top: 2px; }

    /* 作品卡：高階 Glassmorphism 磨砂玻璃設計 */
    .project-list {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 24px;
      margin-top: 32px;
    }
    
    .project {
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      text-decoration: none;
      color: var(--text);
      background: var(--surface); /* 靜態回退 */
      background: color-mix(in srgb, var(--surface) 60%, transparent);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border: 1px solid var(--border);
      border-radius: 24px;
      padding: 24px;
      transition: transform 0.3s cubic-bezier(0.2, 0.8, 0.2, 1),
                  border-color 0.3s,
                  box-shadow 0.3s;
    }

    .project:hover {
      transform: translateY(-6px);
      border-color: var(--g2);
      box-shadow: 0 20px 40px -15px color-mix(in srgb, var(--g2) 35%, transparent);
    }

    .project-header {
      display: flex;
      align-items: center;
      gap: 16px;
      margin-bottom: 16px;
    }

    .project-icon {
      width: 48px;
      height: 48px;
      display: flex;
      align-items: center;
      justify-content: center;
      border-radius: 14px;
      background: linear-gradient(135deg, var(--g1), var(--g2));
      box-shadow: 0 6px 16px -4px color-mix(in srgb, var(--g2) 40%, transparent);
      position: relative;
    }

    .project-icon span {
      font-size: 24px;
      transition: transform 0.3s ease;
    }

    .project:hover .project-icon span {
      transform: scale(1.15) rotate(6deg);
    }

    .project-title-group {
      display: flex;
      flex-direction: column;
      gap: 2px;
      text-align: left;
    }

    .project-title-group strong {
      font-size: 18px;
      font-weight: 700;
      letter-spacing: -0.3px;
    }

    .project-title-group .muted {
      font-size: 13px;
    }

    .pbody {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      text-align: left;
    }

    .pdesc {
      font-size: 13.5px;
      line-height: 1.65;
      margin: 0 0 20px 0;
      color: var(--muted);
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }

    .project-footer {
      display: flex;
      flex-direction: column;
      gap: 12px;
    }

    .tags {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }

    .tag-update {
      align-self: flex-start;
      display: none;
      align-items: center;
      gap: 5px;
      font-size: 11.5px;
      border-style: dashed;
      background: transparent;
      color: var(--muted);
      padding: 3px 8px;
    }

    /* 聯絡我表單容器 (高階 Glassmorphism) */
    .form-container {
      max-width: 580px;
      margin: 40px 0;
      background: var(--surface-2); /* 靜態回退 */
      background: color-mix(in srgb, var(--surface-2) 65%, transparent);
      backdrop-filter: blur(20px);
      -webkit-backdrop-filter: blur(20px);
      border: 1px solid var(--border);
      padding: 36px;
      border-radius: 24px;
      box-shadow: 0 20px 50px -15px rgba(0,0,0,0.12);
      text-align: left;
    }
    .contact-form {
      display: flex;
      flex-direction: column;
      gap: 24px;
    }
    .form-group {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .form-group label {
      font-size: 13px;
      font-weight: 600;
      letter-spacing: 0.5px;
      color: var(--muted);
      padding-left: 2px;
    }
    .form-group input,
    .form-group textarea {
      width: 100%;
      box-sizing: border-box;
      background: var(--surface);
      background: color-mix(in srgb, var(--surface) 50%, transparent);
      border: 1px solid var(--border);
      color: var(--text);
      padding: 14px 18px;
      border-radius: 14px;
      font-size: 14.5px;
      font-family: inherit;
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    .form-group input::placeholder,
    .form-group textarea::placeholder {
      color: color-mix(in srgb, var(--muted) 45%, transparent);
    }
    .form-group input:hover,
    .form-group textarea:hover {
      border-color: color-mix(in srgb, var(--accent) 45%, var(--border));
    }
    .form-group input:focus,
    .form-group textarea:focus {
      border-color: var(--accent);
      outline: none;
      background: var(--surface-2);
      background: color-mix(in srgb, var(--surface-2) 80%, transparent);
      box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent) 15%, transparent);
    }
    #formSubmitBtn {
      align-self: flex-start;
      padding: 12px 28px;
      font-size: 14.5px;
      font-weight: 600;
      border-radius: 12px;
      transition: all 0.3s cubic-bezier(0.2, 0.8, 0.2, 1);
    }
    #formSubmitBtn:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 20px -6px color-mix(in srgb, var(--accent) 50%, transparent);
    }
    #formSubmitBtn:active {
      transform: translateY(0);
    }

    @media (max-width: 960px) {
      .project-list {
        grid-template-columns: repeat(2, 1fr);
        gap: 20px;
      }
    }

    @media (max-width: 640px) {
      .project-list {
        grid-template-columns: 1fr;
        gap: 16px;
      }
    }
  </style>
  
  <script is:inline>
    // 非同步向 GitHub API 抓取公開專案的最後更新時間
    const fetchRepoUpdateDate = (repoName, elementId) => {
      fetch(`https://api.github.com/repos/${repoName}`)
        .then(res => {
          if (!res.ok) throw new Error();
          return res.json();
        })
        .then(data => {
          const date = new Date(data.pushed_at || data.updated_at);
          const formatted = `更新於 ${date.getFullYear()}/${date.getMonth() + 1}/${date.getDate()}`;
          const el = document.getElementById(elementId);
          if (el) {
            el.innerHTML = `
              <svg style="width:11px; height:11px; flex-shrink:0; margin-top:0.5px;" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>${date.getFullYear()}/${date.getMonth() + 1}/${date.getDate()}</span>
            `;
            el.style.display = 'inline-flex';
          }
        })
        .catch(() => {});
    };

    // 只有公開且為開源儲存庫的專案拉取日期
    fetchRepoUpdateDate('Min-987/psd_to_png', 'update-psd-to-png');
    fetchRepoUpdateDate('Min-987/min-987.github.io', 'update-liquid-focus');



    // HubSpot 客製化原生表單非同步 API 串接
    const contactForm = document.getElementById('hsContactForm');
    const formSubmitBtn = document.getElementById('formSubmitBtn');

    if (contactForm && formSubmitBtn) {
      contactForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        const originalText = formSubmitBtn.innerText;
        formSubmitBtn.innerText = '正在傳送...';
        // @ts-ignore
        formSubmitBtn.disabled = true;

        const formData = new FormData(contactForm);
        const email = formData.get('email');
        const firstname = formData.get('firstname');
        const message = formData.get('message');

        // 讀取 HubSpot Cookie (hubspotutk) 用於關聯訪客活動軌跡
        const getCookie = (name) => {
          const value = `; ${document.cookie}`;
          const parts = value.split(`; ${name}=`);
          if (parts.length === 2) return parts.pop().split(';').shift();
          return undefined;
        };
        const hutk = getCookie('hubspotutk');

        // 獲取訪客 IP 以消除 HubSpot 後台警告
        let ipAddress = undefined;
        try {
          const ipResponse = await fetch('https://api.ipify.org?format=json');
          if (ipResponse.ok) {
            const ipData = await ipResponse.json();
            ipAddress = ipData.ip;
          }
        } catch (err) {
          console.warn('Failed to fetch client IP:', err);
        }

        const requestData = {
          fields: [
            { name: 'email', value: email },
            { name: 'firstname', value: firstname },
            { name: 'message', value: message }
          ],
          context: {
            hutk: hutk, // 傳遞 Cookie 以連結現有聯絡人行為分析
            ipAddress: ipAddress,
            pageUri: window.location.href,
            pageName: document.title
          }
        };

        fetch('https://api.hsforms.com/submissions/v3/integration/submit/246598809/edd1001f-05c1-449e-a6d9-34e33a1ec796', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json'
          },
          body: JSON.stringify(requestData)
        })
        .then(res => {
          if (!res.ok) throw new Error();
          return res.json();
        })
        .then(() => {
          contactForm.reset();
          formSubmitBtn.innerText = '已成功送出！';
          // @ts-ignore
          if (window.showToast) {
            // @ts-ignore
            window.showToast('聯絡表單已成功送出，我會盡快回覆您！');
          }
          setTimeout(() => {
            formSubmitBtn.innerText = originalText;
            // @ts-ignore
            formSubmitBtn.disabled = false;
          }, 3000);
        })
        .catch(() => {
          formSubmitBtn.innerText = '傳送失敗，請重試';
          // @ts-ignore
          if (window.showToast) {
            // @ts-ignore
            window.showToast('傳送失敗，請複製 Email 直接來信！');
          }
          setTimeout(() => {
            formSubmitBtn.innerText = originalText;
            // @ts-ignore
            formSubmitBtn.disabled = false;
          }, 3000);
        });
      });
    }

    // 打字機切換效果 (Typing Carousel Effect)
    const words = ['行動 App 📱', '網頁應用 🌐', '桌面工具 🖼️'];
    let wordIndex = 0;
    let charIndex = 0;
    let isDeleting = false;
    const typingTextEl = document.getElementById('typingText');
    
    function typeEffect() {
      if (!typingTextEl) return;
      const currentWord = words[wordIndex];
      if (isDeleting) {
        charIndex--;
      } else {
        charIndex++;
      }
      
      typingTextEl.innerText = currentWord.substring(0, charIndex);
      
      let speed = isDeleting ? 40 : 100;
      
      if (!isDeleting && charIndex === currentWord.length) {
        speed = 2000; // 完整單字停留
        isDeleting = true;
      } else if (isDeleting && charIndex === 0) {
        isDeleting = false;
        wordIndex = (wordIndex + 1) % words.length;
        speed = 400; // 切換新詞間隔
      }
      
      setTimeout(typeEffect, speed);
    }
    
    // 啟動打字效果
    setTimeout(typeEffect, 1000);
  </script>
</Base>
