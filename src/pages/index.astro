---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// 涉獵領域（可自由增刪）
const skills = [
  { k: '行動 App', v: 'iOS · Android' },
  { k: '雲端服務', v: '帳號登入、資料同步' },
  { k: '網站', v: '像你正在看的這個' },
  { k: 'AI 協作', v: '用 AI 加速開發' },
];
---
<Base title="Min — 個人網站" description="Min 的個人網站與作品集。打造實用的行動應用。">

  <!-- Hero -->
  <section class="hero">
    <div class="wrap">
      <h1>嗨，我是 <span class="gradient-text">Min</span> 👋<br/>我打造實用的 App。</h1>
      <p class="lead">
        喜歡把生活中的小麻煩，變成<span class="accent">好用的工具</span>。
        善用各種工具把腦中的點子做成真的能用的東西，
        最新作品是到期日管理 App <span class="accent">ExpiryRP</span>。
      </p>
      <div class="btn-row">
        <a class="btn btn-primary" href={`${base}/#projects`}>看我的作品</a>
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about">
    <div class="wrap">
      <h2>關於我</h2>
      <p>
        比起鑽研艱深的技術，我更在意一個東西<span style="color:var(--text)">好不好用、能不能真的解決問題</span>。
        我喜歡從一個生活中的小困擾出發，一步步把它變成可以實際使用的產品。
      </p>
      <p class="muted">
        在各種現代工具（包含 AI）的協助下，我能把想法快速做成成品——
        ExpiryRP 就是這樣誕生的。我享受這個從零到一、邊做邊學的過程。
      </p>
    </div>
  </section>

  <!-- Skills -->
  <section id="skills">
    <div class="wrap">
      <h2>涉獵領域</h2>
      <div class="skill-grid">
        {skills.map((s) => (
          <div class="skill">
            <div class="k">{s.k}</div>
            <div class="v">{s.v}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section id="projects">
    <div class="wrap">
      <h2>作品</h2>

      <a class="card" href={`${base}/expiryrp`}>
        <div class="row">
          <span class="emoji">📦</span>
          <div>
            <strong style="font-size:18px;">ExpiryRP</strong>
            <div class="muted" style="font-size:14px;">到期日管理工具</div>
          </div>
        </div>
        <p class="muted" style="margin:14px 0 0;">
          掃描條碼記錄物品到期日，到期前主動提醒，減少食物與用品的浪費。
          支援家庭共享、消耗統計與 iOS 桌面小工具。
        </p>
        <div class="tags">
          <span class="tag">Flutter</span>
          <span class="tag">Firebase</span>
          <span class="tag">iOS Widget</span>
          <span class="tag">即將上架</span>
        </div>
      </a>

      <!-- 之後有新作品，複製上面的 <a class="card"> 區塊再加一個就好 -->
    </div>
  </section>

  <!-- Contact -->
  <section id="contact">
    <div class="wrap">
      <h2>聯絡</h2>
      <p>有專案合作、工作機會或單純想聊聊，都歡迎來信 👇</p>
      <div class="btn-row">
        <a class="btn btn-primary" href="mailto:n200127@gmail.com">寄 Email 給我</a>
        <a class="btn btn-ghost" href="https://github.com/Min-987" target="_blank" rel="noopener">GitHub ↗</a>
      </div>
    </div>
  </section>

</Base>
